<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="OpenClawTray.Pages.McpServerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonClick="OnPrimaryClick"
    CloseButtonText="取消"
    DefaultButton="Primary"
    MinWidth="580">

    <StackPanel Spacing="12" Width="520" Padding="4,0,4,4">
        <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBox x:Name="NameBox" Header="名称" Width="240" PlaceholderText="my-server"/>
            <ComboBox x:Name="TransportCombo" Header="类型" Width="220" SelectedIndex="0" SelectionChanged="OnTransportChanged">
                <x:String>stdio</x:String>
                <x:String>streamable-http</x:String>
            </ComboBox>
        </StackPanel>
        <TextBox x:Name="CommandBox" Header="命令 (stdio，如 npx)" PlaceholderText="npx"/>
        <TextBox x:Name="ArgsBox" Header="参数 (stdio，空格分隔)" PlaceholderText="-y @modelcontextprotocol/server-filesystem /tmp"/>
        <TextBox x:Name="EnvBox" Header="环境变量 (stdio，每行 KEY=value，可选)" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="64" PlaceholderText="GITHUB_PERSONAL_ACCESS_TOKEN=ghp_..."/>
        <TextBox x:Name="UrlBox" Header="URL (streamable-http)" Visibility="Collapsed" PlaceholderText="http://localhost:8080/mcp"/>
        <InfoBar x:Name="ErrorBar" IsOpen="False" Severity="Error" IsClosable="False"/>
    </StackPanel>
</ContentDialog>
