<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="OpenClawTray.Pages.McpMyServersControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24,4,24,24" Spacing="12" HorizontalAlignment="Stretch" MaxWidth="1000">

            <!-- 标题行：左「已配置的服务器」+ loading，右「＋ 添加」按钮 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <ProgressRing x:Name="LoadingProgress" IsActive="False" Width="16" Height="16"/>
                    <TextBlock Text="已配置的服务器" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="1" Content="＋ 添加" Click="OnAddClick" Padding="16,7" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" FontSize="12"/>

            <!-- 已配置卡片网格 -->
            <ItemsControl x:Name="ServersList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="284"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="4" Width="276"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="14">
                            <StackPanel Spacing="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                    <Border CornerRadius="8" Padding="8,1" Background="{ThemeResource ControlFillColorSecondaryBrush}" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding TransportBadge}" FontSize="10"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding Display}" FontSize="11" FontFamily="Consolas"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" MaxLines="3" MinHeight="32"/>
                                <TextBlock Text="{Binding EnvHint}" FontSize="10"
                                           Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                           Visibility="{Binding EnvHintVisibility}" TextWrapping="Wrap"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,4,0,0">
                                    <Button Content="编辑" Click="OnEditClick" Tag="{Binding Name}" Padding="14,6" FontSize="12"/>
                                    <Button Content="删除" Click="OnDeleteClick" Tag="{Binding Name}" Padding="14,6" FontSize="12"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 空状态：居中占位 -->
            <StackPanel x:Name="EmptyState" Visibility="Collapsed" Spacing="10" HorizontalAlignment="Center" Margin="0,48,0,0">
                <TextBlock Text="🔌" FontSize="36" HorizontalAlignment="Center"/>
                <TextBlock Text="尚无 MCP 服务器" HorizontalAlignment="Center" FontWeight="SemiBold" FontSize="14"/>
                <TextBlock Text="点右上角「＋ 添加」手动配置，或去「市场」一键安装。"
                           HorizontalAlignment="Center" FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
