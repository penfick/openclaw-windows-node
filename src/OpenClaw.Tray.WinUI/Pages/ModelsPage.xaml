<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.ModelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题行 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="24,16,24,8" Spacing="12" HorizontalAlignment="Stretch" MaxWidth="1100">
            <TextBlock Text="模型配置" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            <Button Content="+ 添加模型" Click="OnAddClick" VerticalAlignment="Center"/>
            <ProgressRing x:Name="LoadingProgress" IsActive="False" Width="18" Height="18" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 卡片区域（并排 wrap） -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,0,24,24">
            <ItemsControl x:Name="CardsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="300"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="14" Margin="4"
                                Width="280">
                            <StackPanel Spacing="8">
                                <!-- 头部：图标 + Provider + 默认徽章 -->
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Icon}" FontSize="20" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ProviderName}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="13"/>
                                    <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="3" Padding="5,1" Visibility="{Binding DefaultBadgeVisibility}" VerticalAlignment="Center">
                                        <TextBlock Text="默认" FontSize="10" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                <!-- 模型名 -->
                                <TextBlock Text="{Binding ModelDisplay}" Style="{StaticResource BodyStrongTextBlockStyle}" TextWrapping="Wrap"/>

                                <!-- 操作按钮 -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0">
                                    <Button Content="编辑" Click="OnEditClick" Padding="10,3" FontSize="12"
                                            Tag="{Binding Key}"/>
                                    <Button Content="设为默认" Click="OnSetDefaultClick" Padding="10,3" FontSize="12"
                                            Tag="{Binding Key}" Visibility="{Binding DefaultBadgeVisibilityInverted}"/>
                                    <Button Content="删除" Click="OnDeleteClick" Padding="10,3" FontSize="12"
                                            Tag="{Binding Key}" Visibility="{Binding DefaultBadgeVisibilityInverted}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
