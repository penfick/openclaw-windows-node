<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.McpConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClawTray.Pages">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Pivot Grid.Row="0" x:Name="Tabs" Margin="0,4,0,0" SelectionChanged="OnTabsSelectionChanged">
            <PivotItem Header="我的服务器">
                <local:McpMyServersControl x:Name="MyServers"/>
            </PivotItem>
            <PivotItem Header="市场">
                <local:McpMarketplaceControl x:Name="Marketplace"/>
            </PivotItem>
        </Pivot>

        <TextBlock Grid.Row="1"
                   Text="MCP 服务器可被聊天中的 Agent 调用，支持 stdio / streamable-http 两种接入方式。"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   FontSize="11" TextWrapping="Wrap"
                   Padding="24,2,24,12" MaxWidth="1000"/>
    </Grid>
</Page>
