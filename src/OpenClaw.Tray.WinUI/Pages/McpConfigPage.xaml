<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.McpConfigPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClawTray.Pages">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Padding="24,16,24,8" Spacing="8" HorizontalAlignment="Stretch" MaxWidth="1000">
            <TextBlock Text="MCP 服务器" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock Text="管理网关的 mcp.servers 配置，或从市场一键安装。stdio / streamable-http MCP 服务器在聊天中可被 Agent 调用。"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <Pivot Grid.Row="1">
            <PivotItem Header="我的服务器">
                <local:McpMyServersControl x:Name="MyServers"/>
            </PivotItem>
            <PivotItem Header="市场">
                <local:McpMarketplaceControl x:Name="Marketplace"/>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
