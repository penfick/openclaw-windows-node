<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="OpenClawTray.Pages.UploadSkillDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="上传到公司市场"
    PrimaryButtonText="上传"
    SecondaryButtonText="取消"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryClick"
    MinWidth="540">

    <StackPanel Spacing="14" MinWidth="480" MaxWidth="500">
        <TextBlock Text="把已安装技能上传到公司 Skills 市场，供同事搜索安装。需要先登录 OA 账号。"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>

        <TextBox x:Name="SlugBox" Header="Slug（唯一标识，英文）" HorizontalAlignment="Stretch"
                 PlaceholderText="my-skill"/>
        <TextBox x:Name="NameBox" Header="名称" HorizontalAlignment="Stretch"/>
        <TextBox x:Name="DescBox" Header="描述" HorizontalAlignment="Stretch"
                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" MaxHeight="120"/>
        <TextBox x:Name="VersionBox" Header="版本" HorizontalAlignment="Stretch" PlaceholderText="1.0.0"/>

        <StackPanel x:Name="ProgressRow" Orientation="Horizontal" Spacing="8" Visibility="Collapsed">
            <ProgressRing x:Name="UpProgress" IsActive="False" Width="16" Height="16"/>
            <TextBlock x:Name="UpStatus" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock x:Name="ErrorText" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Visibility="Collapsed" TextWrapping="Wrap"/>
    </StackPanel>
</ContentDialog>
