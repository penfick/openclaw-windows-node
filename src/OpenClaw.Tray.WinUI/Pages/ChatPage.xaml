<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Enabled">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar — Home/Refresh/DevTools only meaningful when WebView2 mode is active.
             Collapsed by default in native mode so the chat surface starts at the very top. -->
        <Border x:Name="ToolbarBorder" Grid.Row="0"
                Visibility="Collapsed"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1" Padding="8">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <Button x:Name="HomeButton" AutomationProperties.AutomationId="ChatHomeButton"
                        Width="36" Height="36" Padding="0"
                        Visibility="Collapsed"
                        Click="OnHome">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="ChatPageHomeToolTip" Content="Home"/>
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE80F;" FontSize="14"/>
                </Button>
                <Button x:Name="RefreshButton" AutomationProperties.AutomationId="ChatRefreshButton"
                        Width="36" Height="36" Padding="0"
                        Visibility="Collapsed"
                        Click="OnRefresh">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="ChatPageRefreshToolTip" Content="Refresh"/>
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                </Button>
                <Button x:Name="OpenInBrowserButton" AutomationProperties.AutomationId="ChatOpenInBrowserButton"
                        Width="36" Height="36" Padding="0"
                        Visibility="Collapsed"
                        Click="OnPopout">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="ChatPageOpenInBrowserToolTip" Content="Open in Browser"/>
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE8A7;" FontSize="14"/>
                </Button>
                <Button x:Name="DevToolsButton" AutomationProperties.AutomationId="ChatDevToolsButton"
                        Width="36" Height="36" Padding="0"
                        Visibility="Collapsed"
                        Click="OnDevTools">
                    <ToolTipService.ToolTip>
                        <ToolTip x:Uid="ChatPageDeveloperToolsToolTip" Content="Developer Tools"/>
                    </ToolTipService.ToolTip>
                    <FontIcon Glyph="&#xE90F;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Native chat host: the FunctionalUI tree mounts into this Border (default UI). -->
        <Border x:Name="ChatHost" Grid.Row="1"/>

        <!-- WebView2 host: only created/used when "Use standard Gateway Chat interface" is enabled. -->
        <WebView2 x:Name="WebView" Grid.Row="1" Visibility="Collapsed"/>

        <!-- Loading spinner shown while WebView2 navigates. -->
        <ProgressRing x:Name="LoadingRing" Grid.Row="1" IsActive="False"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <StackPanel x:Name="WaitingPanel" Grid.Row="1"
                    Visibility="Collapsed"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock x:Uid="ChatPage_WaitingTitle"
                       Text="Waiting for chat to start…"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="WaitingStatusText" x:Uid="ChatPage_WaitingStatusText"
                       Text="The gateway is connected; the chat surface is still coming online."
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
            <Button x:Name="RetryChatButton" x:Uid="CanvasRetryButton" Content="Retry" Click="OnRetryChat" Visibility="Collapsed"
                    HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Disconnected placeholder (shown when no provider yet). -->
        <StackPanel x:Name="PlaceholderPanel" Grid.Row="1"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <TextBlock Text="💬" FontSize="48" HorizontalAlignment="Center"/>
            <TextBlock x:Uid="ChatPage_TextBlock_53" Text="Connect to gateway to start chatting"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- WebView2 navigation error panel. -->
        <ScrollViewer x:Name="ErrorPanel" Grid.Row="1" Visibility="Collapsed" Padding="20">
            <StackPanel Spacing="12">
                <TextBlock x:Uid="WebChatErrorTitle" Text="Web Chat Unavailable" Style="{StaticResource SubtitleTextBlockStyle}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                <TextBlock x:Name="ErrorText" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                           FontFamily="Consolas" Style="{StaticResource CaptionTextBlockStyle}"/>
                <Button x:Uid="WebChatOpenBrowserButton" Content="Open in Browser Instead" Click="OnPopout" HorizontalAlignment="Left"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Startup connecting overlay: covers the chat area while the gateway is still
             connecting / pairing (before the first successful connection). Lifts once
             connected and never re-shows — later disconnects are handled by the chat
             surface itself. Driven by AppState.Status, NOT provider-null, because the
             functional chat host mounts as soon as an operator client exists (even while
             pairing is still pending), which would otherwise hide a provider-based placeholder. -->
        <Border x:Name="ConnectingOverlay" Grid.Row="1"
                Visibility="Collapsed"
                Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <ProgressRing IsActive="True" Width="40" Height="40" HorizontalAlignment="Center"/>
                <TextBlock x:Uid="ChatPage_GatewayConnectingTitle"
                           Text="正在连接 OpenClaw 网关…"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Uid="ChatPage_GatewayConnectingStatus"
                           Text="请稍等，正在与网关建立连接。"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="360"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
