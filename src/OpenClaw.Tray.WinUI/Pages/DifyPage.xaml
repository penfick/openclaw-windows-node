<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="OpenClawTray.Pages.DifyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:OpenClawTray.Pages">

    <!-- 天音助手：聊天页只管问答；服务地址/API Key 在「天音设置」子页。
         文案硬编码中文（企业内部功能）。 -->

    <Page.Resources>
        <DataTemplate x:Key="UserMsgTemplate">
            <Grid HorizontalAlignment="Right" Margin="0,6" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" HorizontalAlignment="Right" MaxWidth="560"
                        CornerRadius="14,14,2,14" Padding="12,8"
                        Background="{ThemeResource AccentFillColorDefaultBrush}">
                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                               Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"/>
                </Border>
                <Border Grid.Column="1" Width="28" Height="28" CornerRadius="14" VerticalAlignment="Bottom"
                        Background="{ThemeResource AccentFillColorSecondaryBrush}">
                    <TextBlock Text="我" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AssistantMsgTemplate">
            <Grid HorizontalAlignment="Left" Margin="0,6" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14" VerticalAlignment="Bottom"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <TextBlock Text="AI" Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11"/>
                </Border>
                <Border Grid.Column="1" HorizontalAlignment="Left" MaxWidth="660"
                        CornerRadius="14,14,14,2" Padding="12,8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="6">
                        <StackPanel Visibility="{Binding ThinkingVisibility}" Spacing="2">
                            <ToggleButton Content="思考过程" IsChecked="{Binding ThinkingExpanded, Mode=TwoWay}"
                                          Padding="8,2" MinWidth="0" FontSize="12"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Border Visibility="{Binding ThinkingTextVisibility}" Background="{ThemeResource ControlFillColorDefaultBrush}"
                                    CornerRadius="6" Padding="8,6">
                                <TextBlock Text="{Binding Thinking}" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                           FontSize="12" Opacity="0.72"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding Answer}" TextWrapping="Wrap" IsTextSelectionEnabled="True"/>
                        <ProgressRing IsActive="{Binding IsStreaming}" Width="14" Height="14" Visibility="{Binding StreamingVisibility}"/>
                        <ItemsControl ItemsSource="{Binding Citations}" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                            CornerRadius="6" Padding="8" Margin="0,2">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="{Binding DocumentName}" Style="{StaticResource CaptionTextBlockStyle}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap" MaxLines="4"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <local:DifyMessageTemplateSelector x:Key="MsgSelector"
            UserMsgTemplate="{StaticResource UserMsgTemplate}"
            AssistantMsgTemplate="{StaticResource AssistantMsgTemplate}"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 + 清空 -->
        <Grid Grid.Row="0" Padding="24,14,24,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="天音助手" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center"/>
                <StackPanel x:Name="NotConfiguredHint" Orientation="Horizontal" Spacing="6" Visibility="Collapsed" VerticalAlignment="Center">
                    <TextBlock Text="未配置服务地址" Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}"/>
                    <Button Content="前往设置" Click="OnGoSettingsClick" Padding="8,2" MinWidth="0" FontSize="12"/>
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" x:Name="ClearButton" Click="OnClearClick" Content="清空" Padding="10,4" FontSize="12"/>
        </Grid>

        <!-- 消息列表 -->
        <ListView x:Name="MessagesList" Grid.Row="1" Padding="24,4" SelectionMode="None"
                  ItemTemplateSelector="{StaticResource MsgSelector}">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
        </ListView>

        <!-- 输入区 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Padding="24,8">
            <TextBox x:Name="InputBox" Width="640" PlaceholderText="输入你的问题…" KeyDown="OnInputKeyDown"/>
            <Button x:Name="SendButton" Click="OnSendClick" VerticalAlignment="Center">
                <SymbolIcon Symbol="Send"/>
            </Button>
            <ProgressRing x:Name="SendProgress" IsActive="False" Width="18" Height="18" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
