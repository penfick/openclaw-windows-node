<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="OpenClawTray.Pages.EditModelDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonText="保存"
    SecondaryButtonText="取消"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryClick">

    <StackPanel Spacing="12" MinWidth="440">
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="HeaderIcon" FontSize="24"/>
            <TextBlock x:Name="HeaderTitle" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 切换模型 -->
        <StackPanel Spacing="4">
            <TextBlock Text="模型" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
            <ComboBox x:Name="ModelCombo" MinWidth="360"/>
        </StackPanel>

        <!-- API Key（可编辑） -->
        <StackPanel x:Name="ApiKeyPanel" Spacing="4">
            <TextBlock Text="API Key（留空不修改）" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
            <TextBox x:Name="ApiKeyBox" MinWidth="360" PlaceholderText="输入新的 API Key"/>
        </StackPanel>

        <TextBlock x:Name="ErrorText" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Visibility="Collapsed"/>
    </StackPanel>
</ContentDialog>
